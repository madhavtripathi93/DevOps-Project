pipeline {
    agent any

    environment {
        IMAGE_TAG      = "${BUILD_NUMBER}"
        BACKEND_IMAGE  = "madhavtripathi93/agent-backend"
        FRONTEND_IMAGE = "madhavtripathi93/agent-frontend"
        K8S_NAMESPACE  = "devops-project"
        KUBECONFIG     = "/var/jenkins_home/.kube/config"
        DOCKER_BUILDKIT = "1"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        // ── 1. Checkout ─────────────────────────────────────────────
        stage('Checkout') {
            steps {
                cleanWs()
                echo 'Pulling source code...'
                checkout scm
            }
        }

        // ── 2. Test ─────────────────────────────────────────────────
        stage('Test') {
            parallel {
                stage('Test Backend') {
                    steps {
                        sh '''
                            cd AgentMarketplace/backend
                            echo "Run backend tests here"
                        '''
                    }
                }
                stage('Test Frontend') {
                    steps {
                        sh '''
                            cd AgentMarketplace/frontend
                            echo "Run frontend tests here"
                        '''
                    }
                }
            }
        }

        // ── 3. Build ────────────────────────────────────────────────
        stage('Build') {
            parallel {
                stage('Build Backend') {
                    steps {
                        sh '''
                            docker build \
                                -t $BACKEND_IMAGE:$IMAGE_TAG \
                                -t $BACKEND_IMAGE:latest \
                                AgentMarketplace/backend
                        '''
                    }
                }
                stage('Build Frontend') {
                    steps {
                        sh '''
                            docker build \
                                -t $FRONTEND_IMAGE:$IMAGE_TAG \
                                -t $FRONTEND_IMAGE:latest \
                                AgentMarketplace/frontend
                        '''
                    }
                }
            }
        }

        // ── 4. Push ─────────────────────────────────────────
        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin

                        docker push $BACKEND_IMAGE:$IMAGE_TAG
                        docker push $BACKEND_IMAGE:latest

                        docker push $FRONTEND_IMAGE:$IMAGE_TAG
                        docker push $FRONTEND_IMAGE:latest

                        docker logout
                    '''
                }
            }
        }

        // ── 5. Deploy ───────────────────────────────────────────────
        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    echo "── Cluster health ──────────────────────────────"
                    kubectl get nodes

                    echo "── Namespace ───────────────────────────────────"
                    kubectl create namespace $K8S_NAMESPACE \
                        --dry-run=client -o yaml | kubectl apply -f -

                    echo "── MySQL (first-run only) ──────────────────────"
                    if ! kubectl get deployment agent-mysql -n $K8S_NAMESPACE &>/dev/null; then
                        echo "Applying MySQL..."
                        kubectl apply -f kubernetes/agent-marketplace/mysql.yaml -n $K8S_NAMESPACE
                    else
                        echo "MySQL exists — skipping"
                    fi

                    echo "Waiting for MySQL..."
                    kubectl rollout status deployment/agent-mysql -n $K8S_NAMESPACE --timeout=120s || true

                    echo "── Backend & Frontend ──────────────────────────"
                    kubectl apply -f kubernetes/agent-marketplace/backend.yaml -n $K8S_NAMESPACE
                    kubectl apply -f kubernetes/agent-marketplace/frontend.yaml -n $K8S_NAMESPACE

                    echo "── Updating images ─────────────────────────────"
                    kubectl set image deployment/agent-backend \
                        agent-backend=$BACKEND_IMAGE:$IMAGE_TAG -n $K8S_NAMESPACE

                    kubectl set image deployment/agent-frontend \
                        agent-frontend=$FRONTEND_IMAGE:$IMAGE_TAG -n $K8S_NAMESPACE

                    echo "── Cleaning failed pods ───────────────────────"
                    kubectl delete pod -n $K8S_NAMESPACE --field-selector=status.phase=Failed || true

                    echo "── Waiting for rollout ─────────────────────────"
                    kubectl rollout status deployment/agent-backend -n $K8S_NAMESPACE --timeout=300s
                    kubectl rollout status deployment/agent-frontend -n $K8S_NAMESPACE --timeout=300s

                    echo "── Final pod status ───────────────────────────"
                    kubectl get pods -n $K8S_NAMESPACE
                '''
            }
        }

        // ── 6. Monitoring (NEW) ─────────────────────────────────────
        stage('Setup Monitoring (Prometheus)') {
            steps {
                sh '''
                    echo "── Setting up Monitoring ─────────────────────────"

                    kubectl create namespace monitoring \
                        --dry-run=client -o yaml | kubectl apply -f -

                    if ! kubectl get deployment prometheus-kube-prometheus-operator -n monitoring &>/dev/null; then
                        echo "Installing Prometheus..."

                        curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

                        helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
                        helm repo update

                        helm install prometheus prometheus-community/kube-prometheus-stack \
                            --namespace monitoring
                    else
                        echo "Prometheus already installed"
                    fi
                '''
            }
        }

        // ── 7. AIOps (NEW) ─────────────────────────────────────────
        stage('AIOps Analysis') {
            steps {
                sh '''
                    echo "── Running AIOps checks ─────────────────────────"

                    FAILED_PODS=$(kubectl get pods -n $K8S_NAMESPACE \
                        --field-selector=status.phase!=Running \
                        --no-headers | wc -l)

                    if [ "$FAILED_PODS" -gt 0 ]; then
                        echo "⚠️ Detected $FAILED_PODS unhealthy pods"
                        echo "Triggering self-healing..."

                        kubectl rollout restart deployment agent-backend -n $K8S_NAMESPACE || true
                        kubectl rollout restart deployment agent-frontend -n $K8S_NAMESPACE || true
                    else
                        echo "All pods healthy ✅"
                    fi

                    echo "Checking logs..."

                    kubectl logs -n $K8S_NAMESPACE deployment/agent-backend | grep -i error && echo "⚠️ Backend errors detected" || echo "No backend errors"

                    kubectl logs -n $K8S_NAMESPACE deployment/agent-frontend | grep -i error && echo "⚠️ Frontend errors detected" || echo "No frontend errors"
                '''
            }
        }
    }

    // ── Post ───────────────────────────────────────────────────────
    post {
        success {
            echo "PIPELINE SUCCEEDED "
        }

        failure {
            echo "PIPELINE FAILED  — Rolling back..."

            sh '''
                kubectl rollout undo deployment/agent-backend \
                    -n $K8S_NAMESPACE 2>/dev/null || true

                kubectl rollout undo deployment/agent-frontend \
                    -n $K8S_NAMESPACE 2>/dev/null || true
            '''
        }

        always {
            sh '''
                docker rmi $BACKEND_IMAGE:$IMAGE_TAG  2>/dev/null || true
                docker rmi $BACKEND_IMAGE:latest      2>/dev/null || true
                docker rmi $FRONTEND_IMAGE:$IMAGE_TAG 2>/dev/null || true
                docker rmi $FRONTEND_IMAGE:latest     2>/dev/null || true
            '''
            cleanWs()
        }
    }
}
